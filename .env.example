# LLM API key (Groq by default, see api/dependencies.py). A missing or empty
# key does not stop the stack from starting: it surfaces as an error on the
# first query, not at startup.
OPENAI_API_KEY=

# Path inside the container where Milvus Lite stores its database file
INDEX_PATH=/data/index.db

# Host port the frontend is published on
FRONTEND_PORT=80
